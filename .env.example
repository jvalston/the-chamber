# ============================================================
# Mission Control — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored. .env.example is safe to commit.
# ============================================================

# ---- Discord tokens (one bot per agent) --------------------
DISCORD_TOKEN_LEGEND=
DISCORD_TOKEN_SERAPHIM=
DISCORD_TOKEN_DIAMOND=
DISCORD_TOKEN_OLYMPUS=

# ---- Discord room / channel IDs ----------------------------
LEGEND_DISCORD_ROOM=
SERAPHIM_DISCORD_ROOM=
DIAMOND_DISCORD_ROOM=
OLYMPUS_DISCORD_ROOM=
COMMONS_DISCORD_ROOM=
ORIENTATION_DISCORD_ROOM=

# ---- Telegram tokens (one bot per agent) -------------------
TELEGRAM_TOKEN_OLYMPUS=

# ---- Model API keys ----------------------------------------
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ---- Optional service toggles ------------------------------
# Set true/1 when Speak Service is intentionally paused.
SPEAK_SERVICE_DISABLED=false

# ---- Node SSH targets for Mission Control Quick Actions ----
# Lucy (existing)
LUCY_SSH_HOST=100.119.215.107
LUCY_SSH_USER=nana
LUCY_SSH_KEY=~/.ssh/lucy
LUCY_OC_BIN=/home/nana/.npm-global/bin/openclaw

# Axiom (reserved / bring online later)
AXIOM_SSH_HOST=
AXIOM_SSH_USER=nana
AXIOM_SSH_KEY=~/.ssh/axiom
AXIOM_OC_BIN=/usr/bin/openclaw

# Mac Mini (Docker memory host)
MAC_MINI_SSH_HOST=
MAC_MINI_SSH_USER=nana
MAC_MINI_SSH_KEY=~/.ssh/mac-mini
MAC_MINI_OC_BIN=openclaw
